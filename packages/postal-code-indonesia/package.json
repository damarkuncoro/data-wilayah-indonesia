{
  "name": "@damarkuncoro/postal-code-indonesia",
  "version": "1.0.0",
  "description": "Plugin untuk menambahkan kode pos pada data villages Indonesia",
  "exports": {
    ".": {
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js",
      "types": "./lib/index.d.ts"
    },
    "./data/postal-codes.json": "./data/postal-codes.json"
  },
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib",
    "data"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json",
    "test": "jest",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "indonesia",
    "postal",
    "code",
    "kode",
    "pos",
    "plugin",
    "wilayah",
    "administrative"
  ],
  "author": {
    "name": "Damar Kuncoro",
    "email": "damarkuncoro@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/damarkuncoro/postal-code-plugin"
  },
  "bugs": {
    "url": "https://github.com/damarkuncoro/postal-code-plugin/issues"
  },
  "homepage": "https://github.com/damarkuncoro/postal-code-plugin#readme",
  "peerDependencies": {
    "@damarkuncoro/data-wilayah-indonesia": ">=1.0.0"
  },
  "devDependencies": {
    "@damarkuncoro/data-wilayah-indonesia": "^1.2.1",
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
