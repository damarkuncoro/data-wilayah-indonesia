{
  "name": "@damarkuncoro/postal-code-indonesia",
  "version": "1.0.0",
  "description": "Plugin untuk menambahkan kode pos pada data villages Indonesia",
  "exports": {
    ".": {
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js",
      "types": "./lib/index.d.ts"
    },
    "./data/postal-codes.json": "./data/postal-codes.json"
  },
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "types": "./lib/index.d.ts",
"files": [
    "lib",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && cp -r src/data/postal-codes lib/data",
    "prepublishOnly": "npm run build"
  },"keywords": [
    "indonesia",
    "postal",
    "code",
    "kode",
    "pos",
    "plugin",
    "wilayah",
    "administrative"
  ],
  "author": {
    "name": "Damar Kuncoro",
    "email": "damarkuncoro@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/damarkuncoro/postal-code-indonesia"
  },
  "bugs": {
    "url": "https://github.com/damarkuncoro/postal-code-indonesia/issues"
  },
  "homepage": "https://github.com/damarkuncoro/postal-code-indonesia#readme",
  "peerDependencies": {
    "@damarkuncoro/data-wilayah-indonesia": ">=1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
