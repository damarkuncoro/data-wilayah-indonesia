{
  "name": "@damarkuncoro/data-wilayah-indonesia",
  "version": "1.2.1",
  "description": "Package JavaScript/TypeScript untuk data wilayah administratif Indonesia dengan arsitektur pluginable",
  "exports": {
    ".": {
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js",
      "types": "./lib/index.d.ts"
    }
  },
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build-json.js && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "indonesia",
    "wilayah",
    "administrative",
    "province",
    "regency",
    "district",
    "village",
    "data",
    "geographic"
  ],
  "author": {
    "name": "Damar Kuncoro",
    "email": "damarkuncoro@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/damarkuncoro/data-wilayah-indonesia"
  },
  "bugs": {
    "url": "https://github.com/damarkuncoro/data-wilayah-indonesia/issues"
  },
  "homepage": "https://github.com/damarkuncoro/data-wilayah-indonesia#readme",
  "devDependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
