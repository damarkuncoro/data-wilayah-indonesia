{
  "name": "data-wilayah-indonesia",
  "version": "1.0.0",
  "description": "Package JavaScript/TypeScript untuk data wilayah administratif Indonesia",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./data/provinces.json": "./data/provinces.json",
    "./data/regencies.json": "./data/regencies.json",
    "./data/districts.json": "./data/districts.json",
    "./data/villages.json": "./data/villages.json"
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-json.js",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "indonesia",
    "wilayah",
    "administrative",
    "province",
    "regency",
    "district",
    "village",
    "data",
    "geographic"
  ],
  "author": {
    "name": "Nama Anda",
    "email": "email@example.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/username/data-wilayah-indonesia"
  },
  "bugs": {
    "url": "https://github.com/username/data-wilayah-indonesia/issues"
  },
  "homepage": "https://github.com/username/data-wilayah-indonesia#readme",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}